      "targets": [
        {
          "dataset": "gasolineras",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n    date_trunc('hour', p.fecha_consulta) AS \"time\",\n    MIN(p.precio_gasoleo_a)                   AS \"Gasóleo A\",\n    MIN(p.precio_gasolina_95_e5)              AS \"Gasolina 95 E5\",\n    MIN(p.precio_gasolina_98_e5)              AS \"Gasolina 98 E5\",\n    MIN(p.precio_gasoleo_premium)             AS \"Gasóleo Premium\",\n    MIN(p.precio_gasoleo_b)                   AS \"Gasóleo B\",\n    MIN(p.precio_gasolina_95_e5_premium)      AS \"Gasolina 95 E5 Premium\",\n    MIN(p.precio_gasolina_95_e10)             AS \"Gasolina 95 E10\",\n    MIN(p.precio_gasolina_95_e25)             AS \"Gasolina 95 E25\",\n    MIN(p.precio_gasolina_95_e85)             AS \"Gasolina 95 E85\",\n    MIN(p.precio_gasolina_98_e10)             AS \"Gasolina 98 E10\",\n    MIN(p.precio_gasolina_renovable)          AS \"Gasolina Renovable\",\n    MIN(p.precio_biodiesel)                   AS \"Biodiésel\",\n    MIN(p.precio_bioetanol)                   AS \"Bioetanol\",\n    MIN(p.precio_diesel_renovable)            AS \"Diésel Renovable\",\n    MIN(p.precio_adblue)                      AS \"AdBlue\",\n    MIN(p.precio_gases_licuados_petroleo)     AS \"GLP\",\n    MIN(p.precio_gas_natural_comprimido)      AS \"GNC\",\n    MIN(p.precio_gas_natural_licuado)         AS \"GNL\",\n    MIN(p.precio_biogas_natural_comprimido)   AS \"Biogás Natural Comprimido\",\n    MIN(p.precio_biogas_natural_licuado)      AS \"Biogás Natural Licuado\",\n    MIN(p.precio_hidrogeno)                   AS \"Hidrógeno\",\n    MIN(p.precio_amoniaco)                    AS \"Amoníaco\",\n    MIN(p.precio_metanol)                     AS \"Metanol\"\nFROM precios p\nJOIN gasolineras g ON p.ideess = g.ideess\nWHERE g.provincia IN (${provincia:sqlstring})\nGROUP BY date_trunc('hour', p.fecha_consulta)\nORDER BY \"time\";",
          "refId": "A",
          "sql": {
            "columns": [
